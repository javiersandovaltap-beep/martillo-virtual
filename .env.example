# MartilloVirtual - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file (it is in .gitignore).

# === Environment selection ===
# Options: development | production
# - development: SQLite, DEBUG=True, no HTTPS headers
# - production: PostgreSQL (Supabase), DEBUG=False, all security headers
DJANGO_ENV=development

# === Django secret key ===
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# REQUIRED in all environments. If missing, Django raises ImproperlyConfigured.
SECRET_KEY=genera-tu-clave-aqui

# === Debug mode ===
# True only in development. Production.py forces DEBUG=False regardless.
DEBUG=True

# === Allowed hosts ===
# Comma-separated list of hostnames the app can serve.
# Dev: localhost,127.0.0.1
# Prod: tu-app.onrender.com (or your custom domain)
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database URL (production only) ===
# Required when DJANGO_ENV=production.
# Get this from Supabase: Settings > Database > Connection string (URI).
# Format: postgresql://user:password@host:5432/postgres
# Free tier Supabase: 500MB storage, 5 connections.
# Leave empty in development (uses SQLite default).
DATABASE_URL=postgresql://user:password@host:5432/postgres
